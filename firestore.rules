rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function validMode(mode) {
      return mode in ['base', 'timeAttack', 'blackout'];
    }

    function validLeaderboardEntry() {
      return request.resource.data.keys().hasAll(['level', 'time', 'displayName'])
        && request.resource.data.level is int
        && request.resource.data.level >= 1
        && request.resource.data.level <= 500
        && request.resource.data.time is number
        && request.resource.data.time >= 0
        && request.resource.data.time <= 86400000
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() >= 1
        && request.resource.data.displayName.size() <= 20;
    }

    function existingEntry(mode, uid) {
      return get(/databases/$(database)/documents/leaderboards/$(mode)/entries/$(uid));
    }

    function isScoreImprovement(mode, uid) {
      let existing = existingEntry(mode, uid);
      return !existing.exists
        || request.resource.data.level > existing.data.level
        || (request.resource.data.level == existing.data.level
            && mode == 'timeAttack'
            && request.resource.data.time > existing.data.time)
        || (request.resource.data.level == existing.data.level
            && mode != 'timeAttack'
            && request.resource.data.time < existing.data.time);
    }

    function levelJumpOk(mode, uid) {
      let existing = existingEntry(mode, uid);
      return !existing.exists || request.resource.data.level <= existing.data.level + 5;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /runs/{runId} {
      allow read, write: if false;
    }

    match /leaderboards/{mode}/entries/{userId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && validMode(mode)
        && validLeaderboardEntry();
      allow update: if request.auth != null
        && request.auth.uid == userId
        && validMode(mode)
        && validLeaderboardEntry()
        && isScoreImprovement(mode, userId)
        && levelJumpOk(mode, userId);
      allow delete: if request.auth != null
        && request.auth.uid == userId
        && validMode(mode);
    }
  }
}
